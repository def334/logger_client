<UserControl x:Class="logger_client.AIITabInterface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:logger_client="clr-namespace:logger_client"
             xmlns:conv="clr-namespace:logger_client.Converters"
             d:DataContext="{d:DesignInstance Type=logger_client:AIITabInterface}"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="400"
             x:Name="thisControl">

    <UserControl.Resources>
        <conv:LevelToColorConverter x:Key="LevelToColorConverter"/>
        <conv:IndexPlusOneConverter x:Key="IndexPlusOneConverter"/>

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="10"
                          ShadowDepth="2"
                          Direction="270"
                          Color="DarkGray"
                          Opacity="0.4"/>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SpinnerStyle" TargetType="Ellipse">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0" To="360" Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer Background="Transparent"
                      Padding="20"
                      DataContext="{Binding RelativeSource={RelativeSource AncestorType=logger_client:AIITabInterface}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- AI SUMMARY -->
                <Border Background="Transparent"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,12"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="AI SUMMARY"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"/>

                            <TextBlock Text="{Binding CurrentAnalysis.Confidence, StringFormat='  (정확도: {0}%)'}"
                                       Margin="10,0,0,0"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CurrentAnalysis.Description}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMuted}"
                                               LineHeight="20"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- RECOMMENDED FIX -->
                <Border Padding="15">
                    <StackPanel>
                        <TextBlock Text="RECOMMENDED FIX"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding CurrentAnalysis.Solutions}"
                                      AlternationCount="100">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ContentPresenter}}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource IndexPlusOneConverter}}"
                                                   Foreground="#10B981"
                                                   Margin="0,0,8,0"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Top"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#374151"
                                                   LineHeight="20"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 분석 중 오버레이 + 원형 대기바 -->
        <Grid Background="#80000000"
              Visibility="{Binding IsAnalyzing, RelativeSource={RelativeSource AncestorType=logger_client:AIITabInterface}, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="1000">
            <Border Background="#121826"
                    BorderBrush="{StaticResource BorderDark}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="36"
                             Height="36"
                             Stroke="#10B981"
                             StrokeThickness="3"
                             StrokeDashArray="2 3"
                             Style="{StaticResource SpinnerStyle}"/>

                    <TextBlock Text="분석 중..."
                               Margin="0,12,0,0"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
