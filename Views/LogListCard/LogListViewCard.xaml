<UserControl x:Class="logger_client.Views.LogListViewCard"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:logger_client.Views.LogListCard"
             d:DataContext="{d:DesignInstance Type=views:LogListViewCardViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="LocalTabButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1C2432"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1C2432"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource CurveCard}"
                CornerRadius="16"
                Background="{StaticResource Panel2}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#0B0E13"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="0,0,0,1"
                        Padding="14,12">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding CurrentView}" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid x:Name="LogsView">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#121826"
                                    BorderBrush="{StaticResource BorderDark}"
                                    BorderThickness="0,0,0,1"
                                    Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="TimeStamp" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI Semibold"/>
                                    <TextBlock Grid.Column="1" Text="Level" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI Semibold"/>
                                    <TextBlock Grid.Column="2" Text="Source" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI Semibold"/>
                                    <TextBlock Grid.Column="3" Text="Event ID" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" FontFamily="Segoe UI Semibold"/>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                     Padding="0,6,0,10"
                                     HorizontalContentAlignment="Stretch"
                                     ItemsSource="{Binding FilteredLogs}"
                                     SelectedItem="{Binding SelectedLog}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource LogCardBorder}" HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                                           Foreground="{StaticResource TextMuted}"/>

                                                <Border Grid.Column="1"
                                                        Background="{Binding Level, Converter={StaticResource LevelToColorConverter}}"
                                                        CornerRadius="6"
                                                        Padding="8,2"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Level}" FontSize="11" Foreground="White"/>
                                                </Border>

                                                <TextBlock Grid.Column="2" Text="{Binding ProviderName}" FontWeight="SemiBold"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding EventId}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Border Grid.Column="1"
                                Background="{StaticResource Panel2}"
                                BorderBrush="{StaticResource BorderDark}"
                                BorderThickness="1,0,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="LOG DETAILS" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.ColumnSpan="2" Margin="0,0,24,0">
                                                <TextBlock Text="SOURCE" FontSize="11" Foreground="{StaticResource TextMuted}" FontFamily="Cascadia Mono"/>
                                                <TextBlock Text="{Binding SelectedLog.ProviderName}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="TIME" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding SelectedLog.Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="RAW MESSAGE" FontSize="11" Foreground="{StaticResource TextMuted}"/>

                                            <TextBox Grid.Row="1"
                                                     Text="{Binding SelectedLog.Source}"
                                                     Margin="0,8,0,0"
                                                     Background="#0F1115"
                                                     BorderBrush="{StaticResource BorderDark}"
                                                     BorderThickness="1"
                                                     Padding="10"
                                                     FontFamily="Consolas, Cascadia Code, monospace"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     MinHeight="120"
                                                     MaxHeight="220"
                                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="AI ANALYSIS" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,10"/>

                                    <Grid Margin="0,0,0,10">
                                        <Button Height="36"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding AnalyzeSelectedLogCommand}"
                                                Visibility="{Binding ShowAnalyzeButton, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Image Source="/resource/analyze_button_icon.png"
                                                       Width="18"
                                                       Height="18"
                                                       Margin="0,0,0,0"
                                                       Stretch="Uniform"/>
                                                <TextBlock Text="Analyze"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Height="36"
                                                Margin="0,0,0,0"
                                                Style="{StaticResource PrimaryButton}"
                                                Background="DimGray"
                                                Content="{Binding DataContext.ModelDownloadStatus, ElementName=root}"
                                                Command="{Binding DataContext.DownloadModelCommand, ElementName=root}"
                                                Visibility="{Binding DataContext.ShowModelDownloadButton, Converter={StaticResource BoolToVis}, ElementName=root}"/>
                                    </Grid>

                                    <ContentControl Content="{Binding AIInterface}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Highlight 로딩 오버레이 -->
                    <Border Background="#80000000"
                        Panel.ZIndex="100"
                        Visibility="{Binding IsHighlightLoading, Converter={StaticResource BoolToVis}}">
                        <Border Background="#121826"
                            BorderBrush="{StaticResource BorderDark}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Width="300"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Log Highlights 생성 중..."
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,10"/>
                                <ProgressBar IsIndeterminate="True"
                             Height="8"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
            
            
        </Border>
    </Grid>
</UserControl>
